# Server
PORT=3000
FRONTEND_URL=http://localhost:3001
NODE_ENV=development

# Auth (change in production)
JWT_SECRET=dev-secret-change-me

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sqms?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Optional Twilio (leave blank to run in mock mode)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Seed (optional)
SEED_ADMIN_EMAIL=admin@sqms.local
SEED_ADMIN_PASSWORD=admin123

